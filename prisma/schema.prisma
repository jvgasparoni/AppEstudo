generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Question {
  id            Int      @id @default(autoincrement())
  statement     String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  optionE       String
  correctOption String
  explanation   String
  subject       String
  theme         String
  subtheme      String?
  difficulty    String   @default("MEDIUM")
  tags          String
  source        String?
  origin        String   @default("GENERAL")
  lessonNumber  Int?
  reviewed      Boolean  @default(false)
  createdAt     DateTime @default(now())

  attempts      QuestionAttempt[]
  examQuestions ExamQuestion[]

  @@index([origin, lessonNumber])
}

model QuestionAttempt {
  id             Int      @id @default(autoincrement())
  questionId     Int
  examId         Int?
  selectedOption String
  correct        Boolean
  mode           String
  createdAt      DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id])
  exam     Exam?    @relation(fields: [examId], references: [id])
}

model Exam {
  id          Int      @id @default(autoincrement())
  title       String
  randomOrder Boolean  @default(true)
  createdAt   DateTime @default(now())

  examQuestions ExamQuestion[]
  attempts      QuestionAttempt[]
}

model ExamQuestion {
  id         Int @id @default(autoincrement())
  examId     Int
  questionId Int
  position   Int

  exam     Exam     @relation(fields: [examId], references: [id])
  question Question @relation(fields: [questionId], references: [id])
}

model Flashcard {
  id           Int      @id @default(autoincrement())
  front        String
  back         String
  subject      String
  theme        String
  tags         String
  intervalDays Int      @default(1)
  easeFactor   Float    @default(2.5)
  reviewCount  Int      @default(0)
  lapseCount   Int      @default(0)
  nextReview   DateTime @default(now())

  reviews FlashcardReview[]
}

model FlashcardReview {
  id                 Int      @id @default(autoincrement())
  flashcardId        Int
  rating             String
  previousInterval   Int
  newInterval        Int
  previousEaseFactor Float
  newEaseFactor      Float
  reviewedAt         DateTime @default(now())
  nextReview         DateTime

  flashcard Flashcard @relation(fields: [flashcardId], references: [id])
}

model DashboardCounterReset {
  id                     String   @id
  answeredResetAt        DateTime @default(dbgenerated("'1970-01-01T00:00:00.000Z'"))
  accuracyResetAt        DateTime @default(dbgenerated("'1970-01-01T00:00:00.000Z'"))
  allTimeAccuracyResetAt DateTime @default(dbgenerated("'1970-01-01T00:00:00.000Z'"))
  trainAnsweredResetAt   DateTime @default(dbgenerated("'1970-01-01T00:00:00.000Z'"))
  updatedAt              DateTime @updatedAt
}
